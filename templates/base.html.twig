<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>{% block title %}Сталь в интерьерах{% endblock %}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap"
        rel="stylesheet">
  {% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
  {% endblock %}
  {% block javascripts %}
    {{ encore_entry_script_tags('app') }}
  {% endblock %}
</head>
<body>
<header id="header" class="header">
  <div class="container-outer">
    <div class="container">
      <div class="header__wrap">
        <a href="/" class="header__logo"><img src="{{ asset('build/logo.svg') }}" alt="Сталь в интерьерах"/></a>
        <div class="header__contact">
          <div class="header__callback">Заказать звонок</div>
          <a href="#" class="header__phone"><span class="grey">343</span> 305 50 12</a>
        </div>
      </div>
    </div>
  </div>
</header>
<main>
  <div class="side-menu">
    <div class="side-menu__burger"><span></span></div>
    <div class="side-menu__copy"><span>&#169;</span> Сталь в интерьерах, 2021</div>
    <div class="side-menu__socials side-menu__socials_desktop">
      <a target="_blank" href="#" class="side-menu__social">
        {{ source('@public_path'~asset('build/vk.svg')) }}
      </a>
      <a target="_blank" href="#" class="side-menu__social">
        {{ source('@public_path'~asset('build/fb.svg')) }}
      </a>
      <a target="_blank" href="#" class="side-menu__social">
        {{ source('@public_path'~asset('build/inst.svg')) }}
      </a>
    </div>
    <div class="side-menu__list" style="background-image: url('{{ asset('/build/menu-bg.svg') }}')">
      <nav>
        <li class="side-menu__item"><a href="/about" class="side-menu__link">О компании</a></li>
        <li class="side-menu__item"><a href="/portfolio" class="side-menu__link">Портфолио</a></li>
        <li class="side-menu__item"><a href="/catalog" class="side-menu__link">Каталог</a></li>
        <li class="side-menu__item"><a href="/interior" class="side-menu__link">Интерьерные решения</a></li>
        <li class="side-menu__item"><a href="/reviews" class="side-menu__link">Отзывы</a></li>
        <li class="side-menu__item"><a href="#" class="side-menu__link">Контакты</a></li>
      </nav>
      <a href="#" class="side-menu__phone mobile">343 305 50 12</a>
      <div class="side-menu__callback mobile">Заказать звонок</div>
      <div class="side-menu__socials side-menu__socials_mobile">
        <a target="_blank" href="#" class="side-menu__social">
          {{ source('@public_path'~asset('build/vk.svg')) }}
        </a>
        <a target="_blank" href="#" class="side-menu__social">
          {{ source('@public_path'~asset('build/fb.svg')) }}
        </a>
        <a target="_blank" href="#" class="side-menu__social">
          {{ source('@public_path'~asset('build/inst.svg')) }}
        </a>
      </div>
    </div>
  </div>
  <div id="content">
    {% block content %}{% endblock %}
  </div>
</main>
<footer id="footer" class="footer">
  {% block footer %}
    <div class="container-outer">
      <div class="container">
        <div class="footer__wrap">
          <nav class="footer__nav">
            <li><a href="/about" class="footer__link">О компании</a></li>
            <li><a href="/portfolio" class="footer__link">Портфолио</a></li>
            <li><a href="/catalog" class="footer__link">Каталог</a></li>
            <li><a href="/interior" class="footer__link">Интерьерные решения</a></li>
            <li><a href="/reviews" class="footer__link">Отзывы</a></li>
            <li><a href="#" class="footer__link">Контакты</a></li>
          </nav>
          <a href="#" class="footer__dev">
            <div class="footer__dev-logo">
              <img src="{{ asset('build/dev.png') }}" alt="developer logo">
            </div>
            <span>Разработка сайта</span>
          </a>
        </div>
      </div>
    </div>
  {% endblock %}
</footer>
<div class="overlay overlay_header">
  <div class="modal__close"></div>
  <div class="modal modal-header">
    <div class="modal-callback__title">Заказать звонок</div>
    <div class="modal-callback__desc">Отправьте ваши контактные данные и мы свяжемся с вами</div>
    <form action="" class="modal-callback__form">
      <div class="modal-callback__row">
        <div class="modal-callback__field">
          <label for="callback-name" class="modal-callback__label">Ваше имя</label>
          <input type="text" id="callback-name" class="modal-callback__input">
        </div>
        <div class="modal-callback__field">
          <label for="callback-phone" class="modal-callback__label">Номер телефона</label>
          <input type="tel" id="callback-phone" class="modal-callback__input">
        </div>
      </div>
      <input type="submit" class="modal-callback__submit button" value="Отправить">
    </form>
  </div>
</div>
</body>
</html>
